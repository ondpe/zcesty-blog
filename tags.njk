---
pagination:
  data: collections
  size: 1
  alias: tag
permalink: /tags/{{ tag }}/
layout: layouts/base.njk
eleventyComputed:
  title: "{{ tag }} {{ collections[tag] | postYears }}"
  metaDescription: "All posts from the Blog tagged with “{{ tag }}”"
---

{% set postlist = collections[tag] or [] %}
{% set years = postlist | postYears %}

<section class="page-intro">
  <p class="eyebrow">Cesta</p>
  <h1>{{ tag }}{% if years %} {{ years }}{% endif %}</h1>
  <p>Články jsou tady seřazené chronologicky, aby se cesta četla jako deník od začátku do konce.</p>
</section>

<div class="content-grid">
  <section class="content-main">
    {% include "components/postslist.njk" %}
  </section>

  <aside class="content-sidebar" aria-label="Příspěvky v cestě">
    <h2>V téhle cestě</h2>
    <nav class="timeline-list">
      {% for post in postlist %}
        <a href="{{ post.url | url }}">
          <time datetime="{{ post.date | machineDate }}">{{ post.date | czDate }}</time>
          <span>{{ post.data.title }}</span>
        </a>
      {% endfor %}
    </nav>
    <a class="back-link" href="{{ '/' | url }}">Všechny příspěvky</a>
  </aside>
</div>
