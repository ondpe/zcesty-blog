<section class="posts-list">
  {% for post in postlist %}
    <article class="post-card">
      {% if post.data.hero %}
        <a class="post-card-image" href="{{ post.url | url }}">
          <img src="{{ post.data.hero | url }}" alt="" loading="lazy" />
        </a>
      {% endif %}

      <div class="post-card-body">
        <p class="post-date">
          <time datetime="{{ post.date | machineDate }}">{{ post.date | czDate }}</time>
        </p>

        <h2>
          <a href="{{ post.url | url }}">
            {{ post.data.title or "Bez názvu" }}
          </a>
        </h2>

        {% if post.data.summary %}
          <p>{{ post.data.summary }}</p>
        {% endif %}

        {% if post.data.tags %}
          <p class="tag-row">
            {% for tag in post.data.tags %}
              {% if tag != "post" %}
                <a href="/tags/{{ tag | slug }}/" rel="tag">{{ tag }}</a>
              {% endif %}
            {% endfor %}
          </p>
        {% endif %}
      </div>
    </article>
  {% endfor %}
</section>

